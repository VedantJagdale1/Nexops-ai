NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/nexops
CLIENT_URL=http://localhost:5173
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters
REFRESH_TOKEN_SECRET=replace-with-a-different-32-character-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
COOKIE_SECRET=replace-with-at-least-32-characters
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NexOps AI <no-reply@nexops.local>
EMAIL_ENABLED=false
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

